# Firebase Web App yapılandırması (Console > Project settings > Your apps)
# Değerleri web/.env.local içine kopyalayın; bu dosyada gerçek anahtar tutmayın.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_BOOTSTRAP_ADMIN_EMAIL=

# Sunucu API'leri (AI, e-posta, WhatsApp, cron): tek satır JSON servis hesabı
# Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# OpenAI (lead özeti / not düzenleme) — isteğe bağlı
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Resend (giden e-posta)
RESEND_API_KEY=
RESEND_FROM="GOS <onboarding@yourdomain.com>"

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Harici cron (ödeme hatırlatma görevleri) — POST /api/cron/automation
CRON_SECRET=

# Sürüm (web/version.json): npm run build öncesi prebuild patch +1 (odometer). CI’da artışın korunması için güncel version.json’u commit edin. Sadece okumak için: SKIP_VERSION_BUMP=1
SKIP_VERSION_BUMP=
