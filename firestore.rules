rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.role
        : '';
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.role == 'admin';
    }

    function sameUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if signedIn() && (sameUser(userId) || isAdmin());
      allow create: if signedIn() && sameUser(userId)
        && request.resource.data.keys().hasAll(['name', 'email', 'role', 'status'])
        && request.resource.data.email == request.auth.token.email;
      allow update: if isAdmin()
        || (sameUser(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone']));
    }

    match /leads/{leadId} {
      allow read: if isAdmin() || resource.data.ownerId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    match /companies/{companyId} {
      allow read: if signedIn();
      allow write: if signedIn() && (isAdmin() || userRole() == 'business_dev');
    }

    match /contacts/{contactId} {
      allow read: if signedIn();
      allow write: if signedIn() && (isAdmin() || userRole() == 'business_dev');
    }

    match /deals/{dealId} {
      allow read: if isAdmin() || resource.data.ownerId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isAdmin()
        || resource.data.assignedTo == request.auth.uid;
      allow create: if signedIn();
      allow update, delete: if isAdmin()
        || resource.data.assignedTo == request.auth.uid;
    }

    match /tags/{tagId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /proposals/{proposalId} {
      allow read, write: if signedIn() && (isAdmin() || userRole() == 'business_dev');
    }

    match /programs/{programId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow read, write: if signedIn() && (isAdmin() || userRole() == 'operations' || userRole() == 'mentor');
    }
  }
}
